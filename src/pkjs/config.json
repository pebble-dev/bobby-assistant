                "messageKey": "CONFIRM_TRANSCRIPTS",
                "defaultValue": false,
                "label": "Confirm prompts before responding",
                "description": "When enabled, after dictating to the watch, you'll always be asked to confirm your input before Clawd takes action. When disabled, Clawd will respond immediately to whatever was recognised."
